# Kairos — environment variables template
#
# Copy this file to `.env` (git-ignored) and fill in the values you need.
# Kairos never commits `.env` files; only `.env.example` is tracked.
#
# All variables are OPTIONAL. Public market data collection works without
# any API credentials.

# ---------------------------------------------------------------------------
# Network / proxy (only needed if your network blocks the target exchange)
# ---------------------------------------------------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# OKX — only needed for private endpoints (account, orders). Not required for
# K-line / funding / open-interest collection.
# ---------------------------------------------------------------------------
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSPHRASE=

# ---------------------------------------------------------------------------
# Binance — reserved for future use.
# ---------------------------------------------------------------------------
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ---------------------------------------------------------------------------
# Hugging Face — used by kairos-push-hf / from_pretrained fallbacks.
# ---------------------------------------------------------------------------
# HF_TOKEN=
# HF_ENDPOINT=https://hf-mirror.com
